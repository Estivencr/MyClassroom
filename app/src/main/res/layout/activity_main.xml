<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_shape"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="45dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Control de Notas"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.02"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gestión de calificaciones académicas"
                android:textSize="13sp"
                android:textColor="#C5CAE9"
                android:layout_marginBottom="16dp" />

            <!-- Chips de porcentajes -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="N1 · 20%"
                    android:background="@drawable/chip_shape"
                    android:textColor="#C5CAE9"
                    android:textSize="11sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="N2 · 30%"
                    android:background="@drawable/chip_shape"
                    android:textColor="#C5CAE9"
                    android:textSize="11sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="N3 · 15%"
                    android:background="@drawable/chip_shape"
                    android:textColor="#C5CAE9"
                    android:textSize="11sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="N4 · 35%"
                    android:background="@drawable/chip_shape"
                    android:textColor="#C5CAE9"
                    android:textSize="11sp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

            </LinearLayout>
        </LinearLayout>

        <!-- Contenido con padding -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ═══════════════════════════════════════ -->
            <!--          CARD: DATOS ESTUDIANTE         -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <!-- Borde sutil -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal">

                    <!-- Accent lateral -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#3949AB" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Datos del Estudiante"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#3949AB"
                            android:layout_marginBottom="14dp" />

                        <!-- Campo: Nombre -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nombre completo"
                            android:textSize="12sp"
                            android:textColor="#78909C"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/etNombre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Ej: Juan Pérez"
                            android:inputType="textPersonName"
                            android:background="@drawable/input_shape"
                            android:padding="12dp"
                            android:textSize="14sp"
                            android:textColor="#263238"
                            android:textColorHint="#B0BEC5"
                            android:layout_marginBottom="14dp" />

                        <!-- Jornada como segmented control -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jornada"
                            android:textSize="12sp"
                            android:textColor="#78909C"
                            android:layout_marginBottom="6dp" />

                        <RadioGroup
                            android:id="@+id/rgJornada"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:orientation="horizontal"
                            android:background="@drawable/segment_bg"
                            android:padding="4dp"
                            android:layout_marginBottom="14dp">

                            <RadioButton
                                android:id="@+id/rbManana"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Mañana"
                                android:textSize="12sp"
                                android:gravity="center"
                                android:button="@null"
                                android:background="@drawable/radio_selector"
                                android:textColor="@color/radio_text_selector"
                                android:checked="true" />

                            <RadioButton
                                android:id="@+id/rbTarde"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Tarde"
                                android:textSize="12sp"
                                android:gravity="center"
                                android:button="@null"
                                android:background="@drawable/radio_selector"
                                android:textColor="@color/radio_text_selector" />

                            <RadioButton
                                android:id="@+id/rbNoche"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="Noche"
                                android:textSize="12sp"
                                android:gravity="center"
                                android:button="@null"
                                android:background="@drawable/radio_selector"
                                android:textColor="@color/radio_text_selector" />

                        </RadioGroup>

                        <!-- Checkbox becado -->
                        <CheckBox
                            android:id="@+id/cbBecado"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Estudiante becado"
                            android:textColor="#546E7A"
                            android:textSize="13sp"
                            android:background="@drawable/checkbox_bg"
                            android:paddingStart="12dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:buttonTint="#3949AB" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════ -->
            <!--             CARD: NOTAS                 -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_border"
                    android:orientation="horizontal">

                    <!-- Accent lateral -->
                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#00897B" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Header de la card con badge -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Notas"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#00695C" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rango: 1.0 – 5.0"
                                android:background="@drawable/badge_shape"
                                android:textColor="#00695C"
                                android:textSize="10sp"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp" />

                        </LinearLayout>

                        <!-- Grid 2x2 de notas -->
                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:rowCount="2"
                            android:useDefaultMargins="false">

                            <!-- Nota 1 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="6dp"
                                android:layout_marginBottom="10dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nota 1 · 20%"
                                    android:textSize="11sp"
                                    android:textColor="#78909C"
                                    android:layout_marginBottom="4dp" />

                                <EditText
                                    android:id="@+id/etNota1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="0.0"
                                    android:inputType="numberDecimal"
                                    android:background="@drawable/input_shape"
                                    android:padding="10dp"
                                    android:textSize="16sp"
                                    android:textColor="#263238"
                                    android:textStyle="bold"
                                    android:textColorHint="#CFD8DC"
                                    android:gravity="center" />
                            </LinearLayout>

                            <!-- Nota 2 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="6dp"
                                android:layout_marginBottom="10dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nota 2 · 30%"
                                    android:textSize="11sp"
                                    android:textColor="#78909C"
                                    android:layout_marginBottom="4dp" />

                                <EditText
                                    android:id="@+id/etNota2"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="0.0"
                                    android:inputType="numberDecimal"
                                    android:background="@drawable/input_shape"
                                    android:padding="10dp"
                                    android:textSize="16sp"
                                    android:textColor="#263238"
                                    android:textStyle="bold"
                                    android:textColorHint="#CFD8DC"
                                    android:gravity="center" />
                            </LinearLayout>

                            <!-- Nota 3 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nota 3 · 15%"
                                    android:textSize="11sp"
                                    android:textColor="#78909C"
                                    android:layout_marginBottom="4dp" />

                                <EditText
                                    android:id="@+id/etNota3"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="0.0"
                                    android:inputType="numberDecimal"
                                    android:background="@drawable/input_shape"
                                    android:padding="10dp"
                                    android:textSize="16sp"
                                    android:textColor="#263238"
                                    android:textStyle="bold"
                                    android:textColorHint="#CFD8DC"
                                    android:gravity="center" />
                            </LinearLayout>

                            <!-- Nota 4 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_columnWeight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nota 4 · 35%"
                                    android:textSize="11sp"
                                    android:textColor="#78909C"
                                    android:layout_marginBottom="4dp" />

                                <EditText
                                    android:id="@+id/etNota4"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="0.0"
                                    android:inputType="numberDecimal"
                                    android:background="@drawable/input_shape"
                                    android:padding="10dp"
                                    android:textSize="16sp"
                                    android:textColor="#263238"
                                    android:textStyle="bold"
                                    android:textColorHint="#CFD8DC"
                                    android:gravity="center" />
                            </LinearLayout>

                        </GridLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════ -->
            <!--               BOTONES                   -->
            <!-- ═══════════════════════════════════════ -->

            <!-- Fila principal: Agregar + Calcular -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Botón primario: Agregar -->
                <Button
                    android:id="@+id/btnAgregar"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Agregar"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#3949AB"
                    android:layout_marginEnd="6dp"
                    android:stateListAnimator="@null"
                    style="@style/Widget.MaterialComponents.Button" />

                <!-- Botón secundario: Calcular -->
                <Button
                    android:id="@+id/btnCalcular"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Calcular"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:backgroundTint="#E8F5E9"
                    android:layout_marginStart="6dp"
                    android:stateListAnimator="@null"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#A5D6A7"
                    app:strokeWidth="1dp" />

            </LinearLayout>

            <!-- Botón destructivo: Limpiar -->
            <Button
                android:id="@+id/btnLimpiar"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Limpiar todo"
                android:textSize="13sp"
                android:textColor="#C62828"
                android:backgroundTint="#FFEBEE"
                android:layout_marginBottom="16dp"
                android:stateListAnimator="@null"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                app:strokeColor="#FFCDD2"
                app:strokeWidth="1dp" />

            <!-- ═══════════════════════════════════════ -->
            <!--            CARD: RESULTADOS             -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#EEF2FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resultado"
                        android:textSize="12sp"
                        android:textColor="#7986CB"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvResultados"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Agrega un estudiante y presiona Calcular para ver el promedio ponderado."
                        android:textSize="14sp"
                        android:textColor="#5C6BC0"
                        android:lineSpacingExtra="6dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>